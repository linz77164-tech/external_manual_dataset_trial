{
  "extends": [
    "github>nuxt/renovate-config-nuxt"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "baseBranchPatterns": [
    "v2",
    "v3",
    "v4"
  ],
  "ignoreDeps": [
    "typescript",
    "actions/stale"
  ],
  "packageRules": [
    {
      "groupName": "tailwindcss",
      "matchPackageNames": [
        "tailwindcss",
        "@tailwindcss/postcss",
        "@tailwindcss/vite"
      ]
    },
    {
      "groupName": "reka-ui",
      "matchPackageNames": [
        "reka-ui",
        "vaul-vue"
      ]
    },
    {
      "groupName": "tiptap",
      "matchPackageNames": [
        "@tiptap/core",
        "@tiptap/extension-bubble-menu",
        "@tiptap/extension-drag-handle-vue-3",
        "@tiptap/extension-emoji",
        "@tiptap/extension-floating-menu",
        "@tiptap/extension-horizontal-rule",
        "@tiptap/extension-image",
        "@tiptap/extension-mention",
        "@tiptap/extension-placeholder",
        "@tiptap/extension-text-align",
        "@tiptap/markdown",
        "@tiptap/pm",
        "@tiptap/starter-kit",
        "@tiptap/suggestion",
        "@tiptap/vue-3"
      ]
    },
    {
      "groupName": "vite",
      "matchPackageNames": [
        "@vitejs/plugin-vue",
        "vite",
        "vue",
        "vue-router"
      ]
    },
    {
      "matchDepTypes": [
        "peerDependencies"
      ],
      "enabled": false
    },
    {
      "matchDepTypes": [
        "resolutions"
      ],
      "enabled": false
    }
  ],
  "postUpdateOptions": [
    "pnpmDedupe"
  ]
}
